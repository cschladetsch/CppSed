	$(MAKE) $(MAKESILENT) -f CMakeFiles/fastsed_tests.dir/build.make CMakeFiles/fastsed_tests.dir/Test/Source/TestReplacement.cpp.s
.PHONY : Test/Source/TestReplacement.cpp.s

